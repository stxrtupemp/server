# ══════════════════════════════════════════════════════════════════
#  CRM Inmobiliario — Environment Variables
#  Copy this file to .env and fill in the values for your environment.
#  NEVER commit .env to source control.
# ══════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=admin1234
POSTGRES_DB=crm_db

# ── Server ────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Database connection ───────────────────────────────────────────
# In Docker Compose, use host = service name: postgres
# Locally, use: localhost
DATABASE_URL=postgresql://crm_user:admin1234@localhost:5433/crm_db

# ── JWT ───────────────────────────────────────────────────────────
# Minimum 32 characters. Generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=17f40cfcce85fb4484ec6a056ecf7c552fa7610ab17d820d2a3dfa60f72f2a7f1fc37f9cfa9234114a51628a55b67a55
JWT_REFRESH_SECRET=6bf57fc8af30aded3d64c84fe2c56489dac1475a093ca79920db88284df7a207a612090a14c2f7cbb6009351c8270c1e
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ── File uploads ──────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ── Security ──────────────────────────────────────────────────────
# bcrypt rounds: 10 (dev/fast) | 12 (balanced) | 14 (prod/slow)
BCRYPT_ROUNDS=12

# ── Client (Vite) ─────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000/api
VITE_PUBLIC_URL=http://localhost:5173
